{
  "expo": {
    "name": "ChatChit Mobile",
    "slug": "chatchit-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "entryPoint": "./App.js",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "supportsTablet": true,
      "useFrameworks": "static"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.anonymous.chatchitmobile",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Cho phép truy cập thư viện ảnh",
          "cameraPermission": "Cho phép truy cập camera"
        }
      ]
    ]
  }
}